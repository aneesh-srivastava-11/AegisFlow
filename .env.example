# MongoDB Atlas connection string (free tier)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/code-review-ai?retryWrites=true&w=majority

# Google Gemini API Key (from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# GitHub App Configuration
GITHUB_APP_ID=your-github-app-id
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-private-key\n-----END RSA PRIVATE KEY-----"

# Webhook secret (generate with: openssl rand -hex 32)
WEBHOOK_SECRET=your-webhook-secret

# Optional: GitHub Personal Access Token (for manual PR analysis via /api/analyze)
GITHUB_TOKEN=ghp_your-personal-access-token

# Public URL of your deployment
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# GitLab Configuration
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=your-gitlab-webhook-secret

