# ========================================================
# AEGISFLOW ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in the values
# ========================================================

# --------------------------------------------------------
# 1. Database (MongoDB)
# --------------------------------------------------------
# MongoDB Atlas connection string (e.g., mongodb+srv://...)
MONGODB_URI=

# --------------------------------------------------------
# 2. AI Configuration
# --------------------------------------------------------
# Fallback Google Gemini API Key (Get one at https://aistudio.google.com/apikey)
# Note: Users can override this by providing their own key in the dashboard (BYOK)
GEMINI_API_KEY=

# --------------------------------------------------------
# 3. Authentication (Firebase Client)
# --------------------------------------------------------
# Find these in Firebase Console -> Project Settings -> General -> Web App
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --------------------------------------------------------
# 4. Backend Authentication (Firebase Admin)
# --------------------------------------------------------
# Find these in Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key (.json)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: When pasting the private key, keep the "\n" line breaks exact!
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# --------------------------------------------------------
# 5. GitHub Integration (For Production Webhooks)
# --------------------------------------------------------
# Set these after creating a GitHub App in Developer Settings
GITHUB_APP_ID=
# IMPORTANT: When pasting the private key, keep the "\n" line breaks exact!
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
# Webhook secret (Generate a random string: e.g., 'openssl rand -hex 32')
WEBHOOK_SECRET=

# --------------------------------------------------------
# 6. GitLab Integration (Optional)
# --------------------------------------------------------
GITLAB_TOKEN=
GITLAB_API_URL=https://gitlab.com/api/v4
GITLAB_WEBHOOK_SECRET=

# --------------------------------------------------------
# 7. Local Development Overrides
# --------------------------------------------------------
# Public URL of your deployment (used for webhook callbacks and absolute links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: GitHub Personal Access Token 
# Only used for manual local testing if GITHUB_APP_ID is not configured yet.
GITHUB_TOKEN=
